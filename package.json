{
  "name": "ngt-template",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "eslint \"src/**/*.ts\" \"e2e/**/*.ts\" \"*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "format:check": "prettier --check \"*.{json,md}\" \"{src,e2e,scripts}/**/*.{html,css,scss,json}\"",
    "format:write": "prettier --write \"*.{json,md}\" \"{src,e2e,scripts}/**/*.{html,css,scss,json}\"",
    "format:check:ts": "prettier --check \"{src,e2e,scripts}/**/*.{ts,js}\"",
    "format:write:ts": "prettier --write \"{src,e2e,scripts}/**/*.{ts,js}\"",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:spec": "tsc -p tsconfig.karma.json --noEmit",
    "typecheck": "npm run typecheck:app && npm run typecheck:spec",
    "typecheck:templates": "ng build",
    "verify:quick": "npm run lint && npm run typecheck",
    "pretest": "node scripts/check-shadow-specs.js",
    "test": "node --disable-warning=DEP0169 ./node_modules/@angular/cli/bin/ng.js test --watch=false",
    "test:watch": "node --disable-warning=DEP0169 ./node_modules/@angular/cli/bin/ng.js test --watch=true",
    "test:ci": "node --disable-warning=DEP0169 ./node_modules/@angular/cli/bin/ng.js test --watch=false --code-coverage",
    "test:debug": "node --disable-warning=DEP0169 ./node_modules/@angular/cli/bin/ng.js test --browsers=Chrome --watch",
    "test:spec": "node --disable-warning=DEP0169 ./node_modules/@angular/cli/bin/ng.js test --watch=false --include",
    "e2e": "playwright test",
    "e2e:spec": "playwright test --reporter=line",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install",
    "export:ships": "node scripts/export-scavenger-pod-glb.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/common": "^21.0.6",
    "@angular/compiler": "^21.0.6",
    "@angular/core": "^21.0.6",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.6",
    "@angular/platform-browser-dynamic": "^21.0.6",
    "@angular/router": "^21.0.6",
    "@monogrid/gainmap-js": "^3.1.0",
    "@pmndrs/cannon-worker-api": "^2.4.0",
    "@pmndrs/vanilla": "^1.24.0",
    "angular-three": "^4.0.0",
    "angular-three-cannon": "^4.2.1",
    "angular-three-postprocessing": "^4.2.1",
    "angular-three-soba": "^4.0.0",
    "angular-three-tweakpane": "^4.2.1",
    "camera-controls": "^2.9.0",
    "cannon-es": "^0.20.0",
    "cannon-es-debugger": "^1.0.0",
    "i": "^0.3.7",
    "maath": "^0.10.8",
    "ngxtension": "^7.0.2",
    "rxjs": "~7.8.1",
    "socket.io-client": "^4.8.3",
    "stats-gl": "^2.2.8",
    "three": "^0.182.0",
    "three-custom-shader-material": "^6.4.0",
    "three-mesh-bvh": "^0.9.0",
    "three-stdlib": "^2.36.1",
    "troika-three-text": "^0.52.3",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.6",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/jasmine": "^6.0.0",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "angular-three-plugin": "^4.2.1",
    "eslint": "^10.3.0",
    "jasmine-core": "^6.2.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "postcss": "^8.5.3",
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.9.3"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "all",
    "htmlWhitespaceSensitivity": "ignore",
    "plugins": [
      "prettier-plugin-organize-imports",
      "prettier-plugin-tailwindcss"
    ]
  },
  "packageManager": "npm@10"
}

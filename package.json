{
  "name": "ngt-template",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "eslint \"src/**/*.ts\" \"e2e/**/*.ts\" \"*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "format:check": "prettier --check \"*.{json,md}\" \"{src,e2e,scripts}/**/*.{html,css,scss,json}\"",
    "format:write": "prettier --write \"*.{json,md}\" \"{src,e2e,scripts}/**/*.{html,css,scss,json}\"",
    "format:check:ts": "prettier --check \"{src,e2e,scripts}/**/*.{ts,js}\"",
    "format:write:ts": "prettier --write \"{src,e2e,scripts}/**/*.{ts,js}\"",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:spec": "tsc -p tsconfig.spec.json --noEmit",
    "typecheck": "npm run typecheck:app && npm run typecheck:spec",
    "typecheck:templates": "ng build",
    "verify:quick": "npm run lint && npm run typecheck",
    "pretest": "node scripts/check-shadow-specs.js",
    "test": "vitest run --config vitest.config.mts",
    "test:watch": "vitest --config vitest.config.mts",
    "test:ci": "vitest run --config vitest.config.mts --coverage",
    "test:debug": "vitest --config vitest.config.mts --inspect-brk --no-file-parallelism",
    "test:spec": "vitest run --config vitest.config.mts",
    "test:vitest": "vitest run --config vitest.config.mts",
    "test:vitest:watch": "vitest --config vitest.config.mts",
    "test:vitest:ci": "vitest run --config vitest.config.mts --coverage",
    "e2e": "playwright test",
    "e2e:spec": "playwright test --reporter=line",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install",
    "catalog:test": "node scripts/catalog-test.mjs",
    "catalog:audit": "node scripts/audit-backend-item-catalog.mjs",
    "contract:check": "node scripts/sw-08-contract-safety-gate.mjs",
    "contract:check:stage2": "node scripts/sw-08-contract-safety-gate.mjs --mode soft-fail",
    "contract:check:stage3": "node scripts/sw-08-contract-safety-gate.mjs --mode hard-fail",
    "contract:check:stage5": "node scripts/sw-08-contract-safety-gate.mjs --mode hard-fail",
    "contract:check:fixture": "node scripts/sw-08-contract-safety-gate.mjs --frontend-inventory docs/planning/sw-08/frontend-consumer-contract-inventory.intentional-mismatch.json --backend-artifact docs/planning/sw-08/backend-contract-artifact.intentional-mismatch.json",
    "contract:check:stage2:fixture": "node scripts/sw-08-contract-safety-gate.mjs --mode soft-fail --frontend-inventory docs/planning/sw-08/frontend-consumer-contract-inventory.intentional-mismatch.json --backend-artifact docs/planning/sw-08/backend-contract-artifact.intentional-mismatch.json",
    "contract:check:stage2:approved": "node scripts/sw-08-contract-safety-gate.mjs --mode soft-fail --frontend-inventory docs/planning/sw-08/frontend-consumer-contract-inventory.intentional-mismatch.json --backend-artifact docs/planning/sw-08/backend-contract-artifact.intentional-mismatch.json --exception-file docs/planning/sw-08/sw-08-approved-exception.example.json",
    "contract:check:compatibility": "node scripts/sw-08-contract-safety-gate.mjs --mode soft-fail --frontend-inventory docs/planning/sw-08/frontend-consumer-contract-inventory.compatibility.json --backend-artifact docs/planning/sw-08/backend-contract-artifact.json",
    "contract:check:stage3:fixture": "node scripts/sw-08-contract-safety-gate.mjs --mode hard-fail --frontend-inventory docs/planning/sw-08/frontend-consumer-contract-inventory.intentional-mismatch.json --backend-artifact docs/planning/sw-08/backend-contract-artifact.intentional-mismatch.json",
    "contract:check:stage3:approved": "node scripts/sw-08-contract-safety-gate.mjs --mode hard-fail --frontend-inventory docs/planning/sw-08/frontend-consumer-contract-inventory.intentional-mismatch.json --backend-artifact docs/planning/sw-08/backend-contract-artifact.intentional-mismatch.json --exception-file docs/planning/sw-08/sw-08-approved-exception.example.json",
    "contract:check:stage3:expired": "node scripts/sw-08-contract-safety-gate.mjs --mode hard-fail --frontend-inventory docs/planning/sw-08/frontend-consumer-contract-inventory.intentional-mismatch.json --backend-artifact docs/planning/sw-08/backend-contract-artifact.intentional-mismatch.json --exception-file docs/planning/sw-08/sw-08-expired-exception.example.json",
    "contract:check:stage3:missing-approval": "node scripts/sw-08-contract-safety-gate.mjs --mode hard-fail --frontend-inventory docs/planning/sw-08/frontend-consumer-contract-inventory.intentional-mismatch.json --backend-artifact docs/planning/sw-08/backend-contract-artifact.intentional-mismatch.json --exception-file docs/planning/sw-08/sw-08-missing-approval-exception.example.json",
    "export:ships": "node scripts/export-scavenger-pod-glb.mjs"
  },
  "private": true,
  "engines": {
    "node": "20.19.x",
    "npm": "10.9.x"
  },
  "dependencies": {
    "@angular/animations": "21.2.14",
    "@angular/common": "21.2.14",
    "@angular/compiler": "21.2.14",
    "@angular/core": "21.2.14",
    "@angular/forms": "21.2.14",
    "@angular/material": "21.2.14",
    "@angular/platform-browser": "21.2.14",
    "@angular/platform-browser-dynamic": "21.2.14",
    "@angular/router": "21.2.14",
    "@monogrid/gainmap-js": "^3.1.0",
    "@pmndrs/cannon-worker-api": "^2.4.0",
    "@pmndrs/vanilla": "^1.24.0",
    "angular-three": "^4.0.0",
    "angular-three-cannon": "^4.2.2",
    "angular-three-postprocessing": "^4.2.1",
    "angular-three-soba": "^4.2.2",
    "angular-three-tweakpane": "^4.2.1",
    "camera-controls": "^2.10.1",
    "cannon-es": "^0.20.0",
    "cannon-es-debugger": "^1.0.0",
    "i": "^0.3.7",
    "maath": "^0.10.8",
    "ngxtension": "^7.0.2",
    "rxjs": "~7.8.1",
    "socket.io-client": "^4.8.3",
    "stats-gl": "^4.1.0",
    "three": "^0.182.0",
    "three-custom-shader-material": "^6.4.0",
    "three-mesh-bvh": "^0.9.10",
    "three-stdlib": "^2.36.1",
    "troika-three-text": "^0.52.3",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.0",
    "@analogjs/vitest-angular": "^2.6.0",
    "@angular/build": "22.0.3",
    "@angular/cli": "21.2.14",
    "@angular/compiler-cli": "21.2.14",
    "@angular/localize": "21.2.14",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.3",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "vite": "7.3.2"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "all",
    "htmlWhitespaceSensitivity": "ignore",
    "plugins": [
      "prettier-plugin-organize-imports",
      "prettier-plugin-tailwindcss"
    ]
  },
  "packageManager": "npm@10.9.2"
}
